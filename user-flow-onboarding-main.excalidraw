    {
      "id": "mpcde2s3nvyytc7tld",
      "type": "text",
      "x": 475,
      "y": 2295,
      "strokeColor": "#B71C1C",
      "text": "\u2605 THE NO-DEFAULT VALIDATOR \u2605\nPicks Fitz I. Self-quote: \"I got\na sunburn on a somewhat sunny\nday in February in NYC.\" Without\nthe no-default rule, defaulting\nto III would under-estimate his\nburn risk ~50% on first launch.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:27:34.419Z",
      "updatedAt": "2026-05-19T08:27:34.419Z",
      "version": 1,
      "width": 193,
      "height": 96,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1749179655,
      "versionNonce": 1484916708,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779179254419,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2605 THE NO-DEFAULT VALIDATOR \u2605\nPicks Fitz I. Self-quote: \"I got\na sunburn on a somewhat sunny\nday in February in NYC.\" Without\nthe no-default rule, defaulting\nto III would under-estimate his\nburn risk ~50% on first launch.",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "mpcde2s3y1h6t7dyd9e",
      "type": "text",
      "x": 735,
      "y": 2295,
      "strokeColor": "#B71C1C",
      "text": "\u26a0 BRANCH: planning\nat home in Feb. No\ncurrent useful location.\nDenied \u2192 graceful\nempty state. v1 has\nno \"plan-for-elsewhere\"\naffordance (v1.1).",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:27:34.419Z",
      "updatedAt": "2026-05-19T08:27:34.419Z",
      "version": 1,
      "width": 145,
      "height": 96,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",

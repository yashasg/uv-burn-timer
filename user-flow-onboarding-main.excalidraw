    {
      "id": "mpcdatipa9sfqg1k94",
      "type": "text",
      "x": 1275,
      "y": 1810,
      "strokeColor": "#333333",
      "text": "Verdict must hold at:\n  \u00b7 Dynamic Type AX5 (no clipping on SE)\n  \u00b7 VoiceOver rotor navigation\n  \u00b7 Reduce Motion ON (no decorative anim)\n  \u00b7 Increase Contrast (AAA, \u22657:1)\n  \u00b7 Switch Control / AssistiveTouch\n  \u00b7 Polarized-sunglasses OLED test (manual,\n    real device, pre-launch)\n\nTier severity = color + shape + SF Symbol\n+ text (4 channels). systemOrange + white\ntext FAILS AA (3.0:1) \u2014 use black-on-orange\nin Light mode, or HC asset variant.\n\nSkill: outdoor-readability-ios.",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:25:02.449Z",
      "updatedAt": "2026-05-19T08:25:02.449Z",
      "version": 1,
      "width": 283,
      "height": 225,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 710720293,
      "versionNonce": 1225182042,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779179102449,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Verdict must hold at:\n  \u00b7 Dynamic Type AX5 (no clipping on SE)\n  \u00b7 VoiceOver rotor navigation\n  \u00b7 Reduce Motion ON (no decorative anim)\n  \u00b7 Increase Contrast (AAA, \u22657:1)\n  \u00b7 Switch Control / AssistiveTouch\n  \u00b7 Polarized-sunglasses OLED test (manual,\n    real device, pre-launch)\n\nTier severity = color + shape + SF Symbol\n+ text (4 channels). systemOrange + white\ntext FAILS AA (3.0:1) \u2014 use black-on-orange\nin Light mode, or HC asset variant.\n\nSkill: outdoor-readability-ios.",
      "lineHeight": 1.25,
      "autoResize": true
    },

    {
      "id": "mpcd8jp78tait81cyo4",
      "type": "text",
      "x": 920,
      "y": 755,
      "strokeColor": "#333333",
      "text": "DisclosureGroup(\"Inputs\") \u2014 collapsed by\ndefault; auto-expanded at AX4+.\n\n  \u25b8 Skin type  \u2192  SkinTypeView (Fitz I-VI)\n  \u25b8 SPF        \u2192  Picker(.menu)  None/15/30/50/70+\n  \u25b8 Use my location  (.safeAreaInset.bottom)\n                     primary thumb-zone CTA\n\nTimelineView(.periodic(from:.now, by: 60))\n  \u00b7 Updates hero number every minute\n  \u00b7 Pure subtraction from snapshot estimate\n  \u00b7 No background fetch in v1\n\nPull-to-refresh on ScrollView re-fetches UV.\n\nHaptic on tier crossing (.warning) \u2014\ntrail-run / open-water swimmer needs the\nphysical nudge when window elapses.",
      "fontSize": 13,
      "version": 1,
      "width": 357,
      "height": 292,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 2049704361,
      "versionNonce": 1417464629,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779178996411,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DisclosureGroup(\"Inputs\") \u2014 collapsed by\ndefault; auto-expanded at AX4+.\n\n  \u25b8 Skin type  \u2192  SkinTypeView (Fitz I-VI)\n  \u25b8 SPF        \u2192  Picker(.menu)  None/15/30/50/70+\n  \u25b8 Use my location  (.safeAreaInset.bottom)\n                     primary thumb-zone CTA\n\nTimelineView(.periodic(from:.now, by: 60))\n  \u00b7 Updates hero number every minute\n  \u00b7 Pure subtraction from snapshot estimate\n  \u00b7 No background fetch in v1\n\nPull-to-refresh on ScrollView re-fetches UV.\n\nHaptic on tier crossing (.warning) \u2014\ntrail-run / open-water swimmer needs the\nphysical nudge when window elapses.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": null,
      "baseline": 10

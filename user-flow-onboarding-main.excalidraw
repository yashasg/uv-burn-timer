    {
      "id": "mpcde2s35rh5bi7anio",
      "type": "text",
      "x": 220,
      "y": 2395,
      "strokeColor": "#4A148C",
      "text": "\u2605 LOAD-BEARING \u2605  30\u201360 sec dwell.\nSees photo-sens line \u2192 TAPS \"see About\"\ninline \u2192 AboutView opens at notForMe\nanchor (on top of L1) \u2192 reads cohort list\n\u2192 recognizes \"retinoids\" = her Accutane\n\u2192 dismisses \u2192 returns to L1 \u2192 \"I understand\"\nTHIS IS THE VISIBILITY LOOP (not attestation).",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:27:34.419Z",
      "updatedAt": "2026-05-19T08:27:34.419Z",
      "version": 1,
      "width": 278,
      "height": 96,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1882583079,
      "versionNonce": 87523197,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779179254419,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2605 LOAD-BEARING \u2605  30\u201360 sec dwell.\nSees photo-sens line \u2192 TAPS \"see About\"\ninline \u2192 AboutView opens at notForMe\nanchor (on top of L1) \u2192 reads cohort list\n\u2192 recognizes \"retinoids\" = her Accutane\n\u2192 dismisses \u2192 returns to L1 \u2192 \"I understand\"\nTHIS IS THE VISIBILITY LOOP (not attestation).",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "mpcde2s3yla4bzh9r2b",
      "type": "text",
      "x": 475,
      "y": 2395,
      "strokeColor": "#4A148C",
      "text": "Picks Fitz IV (her\nactual phototype).\nRE-READS footer:\n\"assumes healthy skin\n+ no photo-sens meds\"\n\u2014 even though she\nalready saw L1.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:27:34.419Z",

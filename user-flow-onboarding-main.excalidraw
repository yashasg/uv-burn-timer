    },
    {
      "id": "mpcd5e5etv07gv3ear",
      "type": "text",
      "x": 1040,
      "y": 230,
      "strokeColor": "#333333",
      "text": "\u2022 Inline rationale BEFORE iOS prompt\n\u2022 \"When-In-Use\" only (never \"Always\")\n\u2022 Privacy line: \"Coords rounded to\n  2 decimals, never leave device\"\n\u2022 Primary CTA: \"Use my location\"\n  in .safeAreaInset(.bottom) \u2014 thumb\n\u2022 On deny \u2192 graceful empty state,\n  not error string. Re-tap path.\n\u2022 Required because WeatherKit needs\n  location for currentWeather UV\n  (D-2026-05-19-003)\n\u2022 SPF picker also shown here (chip\n  row, neutral, default SPF 30)",
      "fontSize": 12,
      "version": 1,
      "width": 244,
      "height": 195,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 131451864,
      "versionNonce": 399477046,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779178849250,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022 Inline rationale BEFORE iOS prompt\n\u2022 \"When-In-Use\" only (never \"Always\")\n\u2022 Privacy line: \"Coords rounded to\n  2 decimals, never leave device\"\n\u2022 Primary CTA: \"Use my location\"\n  in .safeAreaInset(.bottom) \u2014 thumb\n\u2022 On deny \u2192 graceful empty state,\n  not error string. Re-tap path.\n\u2022 Required because WeatherKit needs\n  location for currentWeather UV\n  (D-2026-05-19-003)\n\u2022 SPF picker also shown here (chip\n  row, neutral, default SPF 30)",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": null,
      "baseline": 9
    },

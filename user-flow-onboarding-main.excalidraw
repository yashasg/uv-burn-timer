    {
      "id": "mpcde2s3nvyytc7tld",
      "type": "text",
      "x": 475,
      "y": 2295,
      "strokeColor": "#B71C1C",
      "text": "\u2605 THE NO-DEFAULT VALIDATOR \u2605\nPicks Fitz I. Self-quote: \"I got\na sunburn on a somewhat sunny\nday in February in NYC.\" Without\nthe no-default rule, defaulting\nto III would under-estimate his\nburn risk ~50% on first launch.",
      "fontSize": 11,
      "version": 1,
      "width": 193,
      "height": 96,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1141485284,
      "versionNonce": 1677490968,
      "index": null,
      "isDeleted": false,

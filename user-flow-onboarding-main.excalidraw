    },
    {
      "id": "mpcey3nhhv9a4tm2w3t",
      "type": "text",
      "x": 75,
      "y": 1810,
      "strokeColor": "#5D4037",
      "roughness": 0,
      "text": "Inline caveat on the hero card carries the\nlearn-more deep-link into AboutView\n(anchor = `notForMe`).\n\nThis keeps the iPhone layout stacked while\npreserving the L3 reach-back pattern.",
      "fontSize": 12,
      "createdAt": "2026-05-19T09:11:08.285Z",
      "updatedAt": "2026-05-19T09:11:08.285Z",
      "version": 1,
      "width": 277,
      "height": 90,
      "angle": 0,
      "backgroundColor": "transparent",

    {
      "id": "mpcewfqg1qx20ipolsch",
      "type": "text",
      "x": 980,
      "y": 698,
      "strokeColor": "#37474F",
      "roughness": 0,
      "text": "\u2022 Large Title nav bar\n\u2022 Safe area top/bottom respected\n\u2022 Tappable targets \u2265 44\u00d744pt\n\u2022 SF Symbols for all icons\n\u2022 Semantic system colors:\n  label \u00b7 secondaryLabel \u00b7 systemBackground\n\u2022 Dynamic Type AX5 reflows the verdict\n  number without truncation\n\u2022 VoiceOver reads each card as one element\n  with combined label + value",
      "fontSize": 13,
      "createdAt": "2026-05-19T09:09:50.632Z",
      "updatedAt": "2026-05-19T09:09:50.632Z",
      "version": 1,
      "width": 307,
      "height": 162,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "opacity": 100,
      "roundness": null,
      "seed": 937151850,
      "versionNonce": 873808369,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779181790632,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022 Large Title nav bar\n\u2022 Safe area top/bottom respected\n\u2022 Tappable targets \u2265 44\u00d744pt\n\u2022 SF Symbols for all icons\n\u2022 Semantic system colors:\n  label \u00b7 secondaryLabel \u00b7 systemBackground\n\u2022 Dynamic Type AX5 reflows the verdict\n  number without truncation\n\u2022 VoiceOver reads each card as one element\n  with combined label + value",
      "lineHeight": 1.25,
      "autoResize": true
    },

      "originalText": "5. Photo-Sens Awareness",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "mpcd5e5e6h9xvprcytq",
      "type": "text",
      "x": 1360,
      "y": 230,
      "strokeColor": "#333333",
      "text": "\u26a0 NOT a separate screen \u2014 three\n   surfaces (per Wheeler \u00a77.3):\n\n(a) Inside L1 modal (step 2):\n    inline \"see About\" \u2192 notForMe\n(b) L3 link on verdict card (next):\n    \"Is this estimate for me?\"\n(c) L4 About section, anchor =\n    notForMe (Wheeler-authored)\n\n\u274c NO \"I'm photosensitive\" toggle\n   (zero special-category data,\n   per Raphael Art.9 / Casey M7)\n\u274c NO brand drug names \u2014 generics\n   only (Plunder)",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:20:49.250Z",
      "updatedAt": "2026-05-19T08:20:49.250Z",
      "version": 1,
      "width": 231,
      "height": 225,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 830274952,
      "versionNonce": 1334266908,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779178849250,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u26a0 NOT a separate screen \u2014 three\n   surfaces (per Wheeler \u00a77.3):\n\n(a) Inside L1 modal (step 2):\n    inline \"see About\" \u2192 notForMe\n(b) L3 link on verdict card (next):\n    \"Is this estimate for me?\"\n(c) L4 About section, anchor =\n    notForMe (Wheeler-authored)\n\n\u274c NO \"I'm photosensitive\" toggle\n   (zero special-category data,\n   per Raphael Art.9 / Casey M7)\n\u274c NO brand drug names \u2014 generics\n   only (Plunder)",
      "lineHeight": 1.25,
      "autoResize": true
    },

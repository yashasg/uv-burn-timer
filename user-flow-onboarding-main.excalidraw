    {
      "id": "mpcde2s396iis1d7hmw",
      "type": "text",
      "x": 995,
      "y": 2395,
      "strokeColor": "#4A148C",
      "text": "\u2605 MOST IMPORTANT L3 TAP IN THE APP \u2605\nVerdict reads \"120 min\" but lived\nexp says ~20 min. TAPS L3 \"Is this\nestimate for me?\" \u2192 AboutView notForMe.\nMentally divides 120 by 4\u20136. Quote:\n\"UV maybe 3 and it looks like I've\nrolled a few. What can I do to stop this?\"",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:27:34.419Z",
      "updatedAt": "2026-05-19T08:27:34.419Z",
      "version": 1,
      "width": 254,
      "height": 96,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,

    {
      "id": "mpcde2s3ubvx4a9s7th",
      "type": "text",
      "x": 1515,
      "y": 2395,
      "strokeColor": "#4A148C",
      "text": "Probably indoors by\nthis point (her cohort\nburns at 5 min of\ngardening). Reads\nelapsed copy as\nratification.",
      "fontSize": 11,
      "version": 1,
      "width": 133,
      "height": 82,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,

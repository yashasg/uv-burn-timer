    },
    {
      "id": "mpcdatiogojdv1mbwma",
      "type": "text",
      "x": 475,
      "y": 1810,
      "strokeColor": "#333333",
      "text": "Eight items Plunder wants attorney sign-off\non before App Store submit (don't block design):\n\n 1. NCBI citation wording in About\n 2. \"Apple Weather\" vs \" Weather\" body prose\n 3. L1 modal final copy (Donatello M1 verbatim?)\n 4. L3 link copy: \"Is this estimate for me?\"\n 5. SPF chip neutrality (no \"recommended\" badge)\n 6. Privacy paragraph wording\n 7. Pricing claim: \"no subscription ever\"\n 8. Banned phrases audit (port from prototype JS)\n\nSurfaces affected:  L1 modal, verdict card,\nSkinTypeView footer, AboutView all sections,\nAttributionView, App Store description.",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:25:02.448Z",
      "updatedAt": "2026-05-19T08:25:02.448Z",
      "version": 1,
      "width": 323,
      "height": 225,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1204169205,
      "versionNonce": 40026427,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779179102448,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Eight items Plunder wants attorney sign-off\non before App Store submit (don't block design):\n\n 1. NCBI citation wording in About\n 2. \"Apple Weather\" vs \" Weather\" body prose\n 3. L1 modal final copy (Donatello M1 verbatim?)\n 4. L3 link copy: \"Is this estimate for me?\"\n 5. SPF chip neutrality (no \"recommended\" badge)\n 6. Privacy paragraph wording\n 7. Pricing claim: \"no subscription ever\"\n 8. Banned phrases audit (port from prototype JS)\n\nSurfaces affected:  L1 modal, verdict card,\nSkinTypeView footer, AboutView all sections,\nAttributionView, App Store description.",
      "lineHeight": 1.25,
      "autoResize": true
    },

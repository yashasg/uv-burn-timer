    {
      "id": "mpcd5e5dtraol2y90e8",
      "type": "text",
      "x": 400,
      "y": 230,
      "strokeColor": "#333333",
      "text": "\u2022 Title: \"How accurate is this for you?\"\n\u2022 Body + \u26a0\ufe0f glyph (Donatello M1)\n\u2022 Children-line on its own row\n\u2022 Inline \"see About\" \u2192 notForMe anchor\n\u2022 Photosensitizer line above the fold\n\u2022 Button: \"I understand\" (single CTA)\n\u2022 Re-fires EVERY cold launch\n\u2022 NO \"Don't Show Again\"",
      "fontSize": 12,
      "version": 1,
      "width": 264,
      "height": 120,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1951393615,
      "versionNonce": 2122152259,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779178849249,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022 Title: \"How accurate is this for you?\"\n\u2022 Body + \u26a0\ufe0f glyph (Donatello M1)\n\u2022 Children-line on its own row\n\u2022 Inline \"see About\" \u2192 notForMe anchor\n\u2022 Photosensitizer line above the fold\n\u2022 Button: \"I understand\" (single CTA)\n\u2022 Re-fires EVERY cold launch\n\u2022 NO \"Don't Show Again\"",
      "lineHeight": 1.25,
      "autoResize": true,

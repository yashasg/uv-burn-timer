      "originalText": "3. Skin-Type Picker (Fitz)",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "mpcd5e5dw0mzqefr9oe",
      "type": "text",
      "x": 720,
      "y": 230,
      "strokeColor": "#333333",
      "text": "\u2022 Header: \"Pick the row that matches\n  what your skin DOES, not its color\"\n\u2022 Rows I\u2013VI, each \u226556pt tap target\n\u2022 \u274c NO default selection (D-...-012)\n\u2022 \u274c NO skin-tone swatches (MMT-3)\n\u2022 Wheeler edited variant copy:\n  I \"Very fair\u2026\", II \"Fair\u2026\", III\n  \"Medium tone\u2026\", IV \"Light-brown\u2026\",\n  V \"Brown\u2026 rarely burns\", VI\n  \"Deeply pigmented\u2026 never burns\"\n\u2022 Cite in About: NCBI NBK481857 +\n  Fitzpatrick 1988 (paraphrase only,\n  D-2026-05-19-009 \u2705)\n\u2022 @State only \u2014 never @AppStorage",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:20:49.249Z",
      "updatedAt": "2026-05-19T08:20:49.249Z",
      "version": 1,
      "width": 244,
      "height": 210,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "roundness": null,
      "seed": 1954108065,
      "versionNonce": 1982587039,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "updated": 1779178849249,
      "link": null,
      "locked": false,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022 Header: \"Pick the row that matches\n  what your skin DOES, not its color\"\n\u2022 Rows I\u2013VI, each \u226556pt tap target\n\u2022 \u274c NO default selection (D-...-012)\n\u2022 \u274c NO skin-tone swatches (MMT-3)\n\u2022 Wheeler edited variant copy:\n  I \"Very fair\u2026\", II \"Fair\u2026\", III\n  \"Medium tone\u2026\", IV \"Light-brown\u2026\",\n  V \"Brown\u2026 rarely burns\", VI\n  \"Deeply pigmented\u2026 never burns\"\n\u2022 Cite in About: NCBI NBK481857 +\n  Fitzpatrick 1988 (paraphrase only,\n  D-2026-05-19-009 \u2705)\n\u2022 @State only \u2014 never @AppStorage",
      "lineHeight": 1.25,
      "autoResize": true
    },

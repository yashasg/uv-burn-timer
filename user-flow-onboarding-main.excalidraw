    {
      "id": "mpcd5e5d1f1uvhgv1ky",
      "type": "text",
      "x": 720,
      "y": 195,
      "strokeColor": "#0D47A1",
      "text": "3. Skin-Type Picker (Fitz)",
      "fontSize": 16,
      "version": 1,
      "width": 228,
      "height": 20,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",

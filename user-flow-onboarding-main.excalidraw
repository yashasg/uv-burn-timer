    {
      "id": "mpcd9ydlduy5rdphhht",
      "type": "text",
      "x": 875,
      "y": 1555,
      "strokeColor": "#BF360C",
      "text": "\ud83d\udccc  240-MINUTE DISPLAY CAP",
      "fontSize": 15,
      "version": 1,
      "width": 206,
      "height": 18,
      "angle": 0,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",

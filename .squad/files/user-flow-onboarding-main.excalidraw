    {
      "id": "mpcdb7k7pwpynh9q19n",
      "type": "text",
      "x": 1680,
      "y": 120,
      "strokeColor": "#1a1a1a",
      "text": "LEGEND",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:25:20.647Z",
      "updatedAt": "2026-05-19T08:25:20.647Z",
      "version": 1
    },
    {
      "id": "mpcdb7k7jp61iv1z7gp",
      "type": "text",
      "x": 1680,
      "y": 145,
      "strokeColor": "#333333",
      "text": "Screen fills (LANE 1):\n  \u2591 light gray   = neutral system screen (splash, verdict)\n  \u2591 red          = L1 disclaimer (mandatory acknowledgment)\n  \u2591 light blue   = system task screen (Fitz, location)\n  \u2591 yellow       = passive moment (no separate screen)\n  \u2591 green        = success / first verdict landing\n\nSub-regions (LANE 2 \u2014 Main Screen):\n  \u2591 green        = verdict card / hero\n  \u2591 light blue   = inputs + timer\n  \u2591 purple       = WeatherKit attribution\n  \u2591 orange       = window-elapsed / re-attestation\n  \u2591 gray         = L2 footer (inert)\n  \u2591 pink         = Settings/About entry \u2192 L4 anchor\n\nArrows:  solid blue = primary linear flow\n         solid orange = annotation pointer\n         (no dashed arrows used in this diagram)",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:25:20.647Z",
      "updatedAt": "2026-05-19T08:25:20.647Z",
      "version": 1
    },
    {
      "id": "mpcdcmovjoxit4265fj",
      "type": "text",
      "x": 60,
      "y": 2010,
      "backgroundColor": "#FFE0B2",
      "strokeColor": "#E65100",
      "text": "LANE 4 \u2014 PERSONA OVERLAYS  (5 swimlanes, one per persona; Suchi-authored \u2014 .squad/files/suchi-persona-annotations.md)",
      "fontSize": 18,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmovyfwy7l5c94g",
      "type": "text",
      "x": 60,
      "y": 2045,
      "strokeColor": "#444444",
      "text": "Columns align horizontally with LANE 1 onboarding screens.  Persona colors per Suchi: Greta=green \u00b7 Maya=blue \u00b7 Devon=red \u00b7 Asha=purple \u00b7 Tom\u00e1s=orange.   Three load-bearing safety annotations are bold-bordered.",
      "fontSize": 13,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },

    {
      "id": "mpcd7f9k31cx4c8h5kg",
      "type": "text",
      "x": 135,
      "y": 878,
      "strokeColor": "#E65100",
      "text": "\ud83d\udeb6 Moderate \u00b7 20-59min",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:22:24.008Z",

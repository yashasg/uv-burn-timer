    {
      "id": "mpcdcmov2irn67820ft",
      "type": "text",
      "x": 75,
      "y": 2098,
      "strokeColor": "#1B5E20",
      "text": "P1  GRETA\ngram-counter\nr/Ultralight\nFitz II/III",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmovnsulb6jb9o",
      "type": "text",
      "x": 215,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "L1 modal: ~4 sec\ndwell. Skims title.\nNever taps inline\n\"see About\" link.\nJTBD: \"Will app\njustify NO backup\nsun shirt?\"",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmov7jpsvwjl6hd",
      "type": "text",
      "x": 475,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "Picks Fitz II or III.\nSelf-classifies in\n~3 sec via burn-\nbehavior copy.\n\u2705 behavior-first\ncopy works.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmovegv4cvn2noq",
      "type": "text",
      "x": 735,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "Reads privacy \u00b6\n(\"no tracking\" is\nprecondition).\nGrants \"When in\nUse.\" One tap.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmov4p77m3ukb88",
      "type": "text",
      "x": 995,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "Glances at integer\n+ context line.\nSanity-checks\nFitz\u00b7SPF\u00b7UV.\nIgnores L3 link.\nMay screenshot.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmovr0uk5a9bv1",
      "type": "text",
      "x": 1255,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "\u2605 L2 footer is\nHER answer to\n\"when reapply?\"\n(\"every 2 hours\nregardless of timer\")\nv1 has no timer.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",
      "updatedAt": "2026-05-19T08:26:26.911Z",
      "version": 1
    },
    {
      "id": "mpcdcmoxps7nv1muan",
      "type": "text",
      "x": 1515,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "Reads window-\nelapsed at rest stop\nwithout urgency.\nReapplies, moves on.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.913Z",
      "updatedAt": "2026-05-19T08:26:26.913Z",
      "version": 1
    },
    {
      "id": "mpcdcmoxvnlmaxyevp9",
      "type": "rectangle",

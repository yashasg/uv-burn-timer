      "x": 100,
      "y": 1050,
      "strokeColor": "#333333",
      "text": " Weather  \u00b7  Data sources \u2192\n(tappable link to weatherkit.apple.com/legal-attribution.html)\n\u2265 .body cap height \u00b7 light/dark variant assets \u00b7 D-2026-05-19-002/003/004",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:23:16.411Z",
      "updatedAt": "2026-05-19T08:23:16.411Z",
      "version": 1

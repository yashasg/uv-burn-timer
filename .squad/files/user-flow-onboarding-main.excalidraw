      "version": 1
    },
    {
      "id": "mpcd7f9klhadq9wunlo",
      "type": "text",
      "x": 340,
      "y": 875,
      "strokeColor": "#666666",
      "text": "Severity = color + shape + SF Symbol + label  (AAA contrast, color-blind safe).  Range mapping:  \u2265240 = Long (\"240+ min\" cap),  60-239 = Long,  20-59 = Moderate,  &lt;20 = Short.",
      "fontSize": 13,
      "createdAt": "2026-05-19T08:22:24.008Z",
      "updatedAt": "2026-05-19T08:22:24.008Z",
      "version": 1
    },
    {
      "id": "mpcd7f9kfu2w3moj788",
      "type": "text",
      "x": 120,
      "y": 920,
      "strokeColor": "#444444",
      "text": "Context line:  \"Fitzpatrick III \u00b7 SPF 30 \u00b7 UV index 6.2\"   (.subheadline, .secondary, combine for VoiceOver)",

      "version": 1
    },
    {
      "id": "mpcd8jp7etabo18hywh",
      "type": "text",
      "x": 540,
      "y": 1025,
      "strokeColor": "#E65100",
      "text": "\u23f0  WINDOW-ELAPSED  /  RE-ATTESTATION moment  (when timer expires or session resumes)",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:23:16.411Z",
      "updatedAt": "2026-05-19T08:23:16.411Z",
      "version": 1
    },
    {
      "id": "mpcd8jp86g43qs54kiv",
      "type": "text",
      "x": 540,
      "y": 1050,
      "strokeColor": "#333333",
      "text": "When elapsed \u2265 original estimate:  hero swaps to \ud83d\udee1 \"Estimated window elapsed. Cover up, reapply, or move to shade.\"\nSingle warning haptic.  Button: \"Recalculate\" (.borderedProminent).  This is the safety-critical moment \u2014 must NOT be quiet.\nOn every recalculate, the L1 footer + L3 link remain visible \u2014 photosensitizers re-encounter the disclaimer surface.",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:23:16.412Z",
      "updatedAt": "2026-05-19T08:23:16.412Z",
      "version": 1
    },
    {
      "id": "mpcd8jp8zwlgdct4wp",
      "type": "rectangle",
      "x": 80,
      "y": 1140,
      "width": 1280,
      "height": 60,
      "backgroundColor": "#EEEEEE",
      "strokeColor": "#616161",
      "strokeWidth": 2,
      "createdAt": "2026-05-19T08:23:16.412Z",
      "updatedAt": "2026-05-19T08:23:16.412Z",
      "version": 1
    },
    {
      "id": "mpcd8jp8z46xqn8eo5d",
      "type": "text",
      "x": 100,
      "y": 1148,
      "strokeColor": "#424242",
      "text": "L2 FOOTER (Donatello M2 \u2014 persistent, inert, secondary label color, .footnote, NOT tappable):",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:23:16.412Z",
      "updatedAt": "2026-05-19T08:23:16.412Z",
      "version": 1
    },
    {
      "id": "mpcd8jp8nn8777n09b",
      "type": "text",
      "x": 100,
      "y": 1170,
      "strokeColor": "#212121",
      "text": "\"Estimate only. Not medical advice. Cover up if skin reddens. Reapply sunscreen every 2 hours.\"   \u24d8 About",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:23:16.412Z",
      "updatedAt": "2026-05-19T08:23:16.412Z",
      "version": 1
    },
    {
      "id": "mpcd8jp8iouhvwylcf",
      "type": "rectangle",

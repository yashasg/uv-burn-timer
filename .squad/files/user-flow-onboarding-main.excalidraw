      "type": "text",
      "x": 60,
      "y": 60,
      "strokeColor": "#555555",
      "text": "Source: .squad/decisions/archive/linka-ios-design-spec.md  \u00b7  Decisions: D-2026-05-19-002/003/004/007/011/012  \u00b7  Picker copy: Wheeler edited variant (D-2026-05-19-009 \u2705)",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:19:55.267Z",
      "updatedAt": "2026-05-19T08:19:55.267Z",
      "version": 1
    },
    {

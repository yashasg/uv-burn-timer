      "version": 1
    },
    {
      "id": "mpcdcmox395q3t37i3",
      "type": "text",
      "x": 75,
      "y": 2198,
      "strokeColor": "#0D47A1",
      "text": "P2  MAYA\nopen-water swim\nr/OpenWaterSwim\nFitz III",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:26:26.913Z",
      "updatedAt": "2026-05-19T08:26:26.913Z",
      "version": 1
    },
    {
      "id": "mpcdcmoyfgbyxfpgb9",
      "type": "text",
      "x": 215,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "~6 sec dwell.\nReads \"skin\nresponse varies\"\nline. Lived\nexp: SPF50+70\nstill burned.\nDoesn't tap link.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoy272dv55dg3j",
      "type": "text",
      "x": 475,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "Picks Fitz III. SE\nAsia. Section\nheader (\"not what\ncolor it is\") is\nload-bearing \u2014\ndefeats Eurocentric\n\"Type IV = olive.\"",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoyupf8deee1b",
      "type": "text",
      "x": 735,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "At beach, wet\nhands. Taps big\nbutton. Grants.\nDoesn't read\nprivacy copy.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoypw8yzbd3yom",
      "type": "text",
      "x": 995,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "Compares to 90-min\nswim. Decides to\nshorten. \u26a0 blindspot:\nwater reflection +10%\n& wash-off not modeled.\nPre-swim verdict\nmust be right.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoybpov8hlub2",
      "type": "text",
      "x": 1255,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "\u2605 Pull-to-refresh\nis HER primary\naffordance. Cold-\nlaunches app\ntwice (pre-swim,\npost-warmup).",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoyou2c5gwo85",
      "type": "text",
      "x": 1515,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "In water \u2014 CAN'T\nsee this state.\nWhy the pre-swim\nverdict has to be\nright the first time.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcde2s29xiw4sq2zn",
      "type": "rectangle",
      "x": 60,
      "y": 2290,
      "width": 140,
      "height": 88,
      "backgroundColor": "#FFCDD2",

    {
      "id": "mpcd7f9k7h6mue08p0c",
      "type": "text",
      "x": 135,
      "y": 957,
      "strokeColor": "#0D47A1",
      "text": "\u24d8  Is this estimate for me?   \u2190 L3",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:22:24.008Z",

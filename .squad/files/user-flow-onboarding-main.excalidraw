      "x": 395,
      "y": 957,
      "strokeColor": "#666666",
      "text": "\u2192 deep-links to AboutView, scrolled to `notForMe` anchor (Suchi L3 pattern, persona-keyed)",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:22:24.008Z",

    {
      "id": "mpcd48hv7d6ujjecyml",
      "type": "text",
      "x": 60,
      "y": 60,
      "strokeColor": "#555555",
      "text": "Source: .squad/decisions/archive/linka-ios-design-spec.md  ·  Decisions: D-2026-05-19-002/003/004/007/011/012  ·  Picker copy: Wheeler edited variant (D-2026-05-19-009 ✅)",
      "fontSize": 14,
      "createdAt": "2026-05-19T08:19:55.267Z",
      "updatedAt": "2026-05-19T08:19:55.267Z",
      "version": 1

    },
    {
      "id": "mpcdcmoy272dv55dg3j",
      "type": "text",
      "x": 475,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "Picks Fitz III. SE\nAsia. Section\nheader (\"not what\ncolor it is\") is\nload-bearing —\ndefeats Eurocentric\n\"Type IV = olive.\"",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",

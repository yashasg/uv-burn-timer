    {
      "id": "mpcewfqgn04440vfbf",
      "type": "text",
      "x": 980,
      "y": 666,
      "strokeColor": "#263238",
      "roughness": 0,
      "text": "iOS / HIG notes",
      "fontSize": 16,
      "createdAt": "2026-05-19T09:09:50.632Z",
      "updatedAt": "2026-05-19T09:09:50.632Z",
      "version": 1
    },
    {
      "id": "mpcewfqg1qx20ipolsch",
      "type": "text",
      "x": 980,
      "y": 698,
      "strokeColor": "#37474F",
      "roughness": 0,
      "text": "• Large Title nav bar\n• Safe area top/bottom respected\n• Tappable targets ≥ 44×44pt\n• SF Symbols for all icons\n• Semantic system colors:\n  label · secondaryLabel · systemBackground\n• Dynamic Type AX5 reflows the verdict\n  number without truncation\n• VoiceOver reads each card as one element\n  with combined label + value",
      "fontSize": 13,
      "createdAt": "2026-05-19T09:09:50.632Z",
      "updatedAt": "2026-05-19T09:09:50.632Z",
      "version": 1
    },
    {
      "id": "mpcewfqgymreanrnze",
      "type": "text",
      "x": 980,
      "y": 934,
      "strokeColor": "#455A64",
      "roughness": 0,
      "text": "Single-column stack.\nNo tabs. No sidebar. No dashboard grid.",
      "fontSize": 13,
      "createdAt": "2026-05-19T09:09:50.632Z",
      "updatedAt": "2026-05-19T09:09:50.632Z",
      "version": 1
    },
    {
      "id": "mpcey3ng06wpw8dawuy3",
      "type": "arrow",
      "x": 1780,

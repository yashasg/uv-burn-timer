    {
      "id": "mpcdatiogojdv1mbwma",
      "type": "text",
      "x": 475,
      "y": 1810,
      "strokeColor": "#333333",
      "text": "Pre-submit legal/compliance closure notes:\n\n 1. NCBI citation wording appears in About\n 2. Public UI uses \"Apple Weather\" prose\n 3. L1 modal final copy is implemented\n 4. L3 link copy points to About/applicability\n 5. SPF chips stay neutral; no recommended badge\n 6. Privacy copy: rounded coords sent to Apple\n    Weather; only last rounded coord may be saved\n 7. Pricing: paid app, no subscription/IAP/tip jar\n 8. Banned phrases audit covered by tests\n\nSurfaces affected: L1 modal, verdict card,\nSkinTypeView footer, AboutView all sections,\nAttributionView, App Store description.",
      "fontSize": 12,
      "createdAt": "2026-05-19T08:25:02.448Z",
      "updatedAt": "2026-05-19T08:25:02.448Z",
      "version": 1
    },

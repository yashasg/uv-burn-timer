      "type": "text",
      "x": 60,
      "y": 1480,
      "backgroundColor": "#FFE0B2",
      "strokeColor": "#E65100",
      "text": "LANE 3 — KEY BRANCH POINTS  &  ANNOTATIONS  (where the design materially differs from a naïve flow)",

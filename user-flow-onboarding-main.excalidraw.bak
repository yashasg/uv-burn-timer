      "version": 1
    },
    {
      "id": "mpcdcmoyupf8deee1b",
      "type": "text",
      "x": 735,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "At beach, wet\nhands. Taps big\nbutton. Grants.\nDoesn't read\nprivacy copy.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoypw8yzbd3yom",
      "type": "text",
      "x": 995,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "Compares to 90-min\nswim. Decides to\nshorten. ⚠ blindspot:\nwater reflection +10%\n& wash-off not modeled.\nPre-swim verdict\nmust be right.",

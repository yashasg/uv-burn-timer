      "x": 475,
      "y": 2095,
      "strokeColor": "#1B5E20",
      "text": "Picks Fitz II or III.\nSelf-classifies in\n~3 sec via burn-\nbehavior copy.\n✅ behavior-first\ncopy works.",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.911Z",

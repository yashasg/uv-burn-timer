      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
    },
    {
      "id": "mpcdcmoybpov8hlub2",
      "type": "text",
      "x": 1255,
      "y": 2195,
      "strokeColor": "#0D47A1",
      "text": "★ Pull-to-refresh\nis HER primary\naffordance. Cold-\nlaunches app\ntwice (pre-swim,\npost-warmup).",
      "fontSize": 11,
      "createdAt": "2026-05-19T08:26:26.914Z",
      "updatedAt": "2026-05-19T08:26:26.914Z",
      "version": 1
